# Arkos Intelligence Dashboard - Environment Config
# -----------------------------------------------

# GitHub Personal Access Token (PAT)
# Required for GITHUB API integration.
# Do NOT prefix with "token " here, just the hash.
GITHUB_TOKEN=your_token_here_github_pat_...

# BrasilAPI Key (if using specific premium tiers)
# BRASIL_API_KEY=...

# Backend Config
DEBUG=True
PORT=8000
